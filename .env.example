# Discord Bot Configuration
DISCORD_TOKEN=your_discord_token_here

# Database Configuration
DATABASE_URL=postgres://username:password@localhost:5432/quotient_db

# Bot Owner & Developers
OWNER_ID=your_user_id
DEVS=user_id_1,user_id_2,user_id_3

# Bot Settings
PREFIX=u
COLOR=0xEE4B2B
FOOTER=ULTRA BOT OFFICIAL!!!
PRIME_EMOJI=⚡

# Server Configuration
SERVER_LINK=https://discord.gg/your_server_link
SERVER_ID=your_server_id
TOURNEY_CSV_CHANNEL=your_channel_id
EMOJIS_SERVER=server_id_1,server_id_2

# Bot Invite
BOT_INVITE=your_bot_invite_url

# Logging Channels
SHARD_LOG=your_log_channel_id
ERROR_LOG=your_error_log_id
PUBLIC_LOG=your_public_log_id

# External Services
WEBSITE=https://www.synaphack.in
REPOSITORY=https://www.synaphack.in
FASTAPI_URL=https://your_fastapi_url
FASTAPI_KEY=your_fastapi_key
